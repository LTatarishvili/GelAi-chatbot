# ─────────────────────────────────────────
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Anthropic API (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxx

# Facebook (from developers.facebook.com → your app)
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxx
FB_VERIFY_TOKEN=allsale_secret_2024

# Telegram (from @BotFather + your own chat ID)
TELEGRAM_BOT_TOKEN=123456789:ABCxxxxxxx
TELEGRAM_CHAT_ID=your_telegram_user_id

# Server port (Railway sets this automatically)
PORT=3000
